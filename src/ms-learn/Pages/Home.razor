@page "/"
@inject TranscriptService TranscriptSvc
@inject IJSRuntime JS

<PageTitle>MS Learn Dashboard</PageTitle>

@if (_loading)
{
    <div class="text-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-muted">Loading transcript data...</p>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger mt-4">
        <h4><i class="bi bi-exclamation-triangle-fill"></i> Error Loading Data</h4>
        <p class="mb-0">@_error</p>
    </div>
}
else if (_transcript == null)
{
    <div class="alert alert-warning mt-4">No transcript data available.</div>
}
else
{
    var activeCertifications = _transcript.CertificationData?.ActiveCertifications ?? new List<Certification>();
    var historicalCertifications = _transcript.CertificationData?.HistoricalCertifications ?? new List<Certification>();
    var momentum = BuildMomentumInsight(_transcript.ModulesCompleted);
    var roleFocus = BuildFocusShift(_transcript.ModulesCompleted, m => m.Roles.Select(GroupRole), roleGroup => roleGroup);
    var productFocus = BuildFocusShift(_transcript.ModulesCompleted, m => m.Products, FormatProduct);
    var levelMix = BuildLevelMix(_transcript.ModulesCompleted, 90);
    var milestones = BuildMilestones(activeCertifications, historicalCertifications, _transcript.AppliedSkills, _transcript.Trophies);

    <div class="dashboard-header py-4 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="ms-learn-logo">
                <i class="bi bi-mortarboard-fill fs-1 text-primary"></i>
            </div>
            <div>
                <h1 class="mb-0 fw-bold">@_transcript.UserDisplayName</h1>
                <p class="text-muted mb-0">@_transcript.UserName &nbsp;·&nbsp;
                    <a href="https://learn.microsoft.com/en-us/users/@_transcript.UserName/" target="_blank" rel="noopener">
                        View on MS Learn <i class="bi bi-box-arrow-up-right small"></i>
                    </a>
                </p>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="stat-icon bg-primary-subtle rounded-circle mx-auto mb-3">
                        <i class="bi bi-collection-fill text-primary fs-4"></i>
                    </div>
                    <h2 class="fw-bold mb-1">@_transcript.TotalModulesCompleted</h2>
                    <p class="text-muted small mb-0">Modules Completed</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="stat-icon bg-success-subtle rounded-circle mx-auto mb-3">
                        <i class="bi bi-clock-fill text-success fs-4"></i>
                    </div>
                    <h2 class="fw-bold mb-1">@(_transcript.TotalTrainingMinutes / 60)</h2>
                    <p class="text-muted small mb-0">Training Hours</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="stat-icon bg-warning-subtle rounded-circle mx-auto mb-3">
                        <i class="bi bi-star-fill text-warning fs-4"></i>
                    </div>
                    <h2 class="fw-bold mb-1">@_transcript.ModulesCompleted.Sum(m => m.Xp).ToString("N0")</h2>
                    <p class="text-muted small mb-0">Total XP</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="stat-icon bg-danger-subtle rounded-circle mx-auto mb-3">
                        <i class="bi bi-patch-check-fill text-danger fs-4"></i>
                    </div>
                    <h2 class="fw-bold mb-1">@activeCertifications.Count</h2>
                    <p class="text-muted small mb-0">Active Certifications</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Secondary Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-lg-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="stat-icon bg-info-subtle rounded-circle mx-auto mb-3">
                        <i class="bi bi-mortarboard-fill text-info fs-4"></i>
                    </div>
                    <h2 class="fw-bold mb-1">@_transcript.AppliedSkills.Count</h2>
                    <p class="text-muted small mb-0">Applied Skills</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="stat-icon bg-secondary-subtle rounded-circle mx-auto mb-3">
                        <i class="bi bi-clock-history text-secondary fs-4"></i>
                    </div>
                    <h2 class="fw-bold mb-1">@historicalCertifications.Count</h2>
                    <p class="text-muted small mb-0">Historical Certifications</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <div class="card stat-card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="stat-icon bg-warning-subtle rounded-circle mx-auto mb-3">
                        <i class="bi bi-trophy-fill text-warning fs-4"></i>
                    </div>
                    <h2 class="fw-bold mb-1">@_transcript.Trophies.Count</h2>
                    <p class="text-muted small mb-0">Trophies</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Momentum and Focus -->
    <div class="card border-0 shadow-sm mb-4 momentum-card">
        <div class="card-header bg-transparent border-0 pt-3 pb-0">
            <h5 class="fw-semibold mb-0"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Momentum and Focus</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-lg-4">
                    <div class="insight-panel h-100">
                        <p class="text-uppercase x-small text-muted mb-1">Learning Momentum</p>
                        <div class="d-flex align-items-baseline gap-2 mb-2">
                            <h2 class="fw-bold mb-0">@momentum.Score</h2>
                            <span class="badge @(momentum.Delta30 >= 0 ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                @((momentum.Delta30 >= 0 ? "+" : "") + momentum.Delta30) vs prior 30d
                            </span>
                        </div>
                        <p class="small text-muted mb-2">@momentum.Summary</p>
                        <div class="momentum-sparkline-wrap mb-2">
                            <canvas id="momentumSparkline"></canvas>
                        </div>
                        <div class="d-flex justify-content-between x-small text-muted mb-2">
                            <span>7d</span>
                            <span>30d</span>
                            <span>90d</span>
                        </div>
                        <div class="small">
                            <div class="d-flex justify-content-between"><span>Last 30 days</span><strong>@momentum.Last30 modules</strong></div>
                            <div class="d-flex justify-content-between"><span>Previous 30 days</span><strong>@momentum.Previous30 modules</strong></div>
                            <div class="d-flex justify-content-between"><span>Last 90 days</span><strong>@momentum.Last90 modules</strong></div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="insight-panel h-100">
                        <p class="text-uppercase x-small text-muted mb-2">Focus Shift (90d vs prior 90d)</p>
                        <p class="fw-semibold small mb-2">Roles</p>
                        @if (roleFocus.Any())
                        {
                            @foreach (var item in roleFocus.Take(4))
                            {
                                <div class="d-flex justify-content-between align-items-center focus-row">
                                    <span class="small">@item.Name</span>
                                    <span class="small @(item.Delta >= 0 ? "text-success" : "text-danger")">
                                        <i class="bi bi-@(item.Delta >= 0 ? "arrow-up-right" : "arrow-down-right")"></i>
                                        @((item.Delta >= 0 ? "+" : "") + item.Delta)
                                    </span>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="small text-muted mb-2">Not enough recent role data.</p>
                        }

                        <p class="fw-semibold small mt-3 mb-2">Products</p>
                        @if (productFocus.Any())
                        {
                            @foreach (var item in productFocus.Take(4))
                            {
                                <div class="d-flex justify-content-between align-items-center focus-row">
                                    <span class="small">@item.Name</span>
                                    <span class="small @(item.Delta >= 0 ? "text-success" : "text-danger")">
                                        <i class="bi bi-@(item.Delta >= 0 ? "arrow-up-right" : "arrow-down-right")"></i>
                                        @((item.Delta >= 0 ? "+" : "") + item.Delta)
                                    </span>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="small text-muted mb-0">Not enough recent product data.</p>
                        }
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="insight-panel h-100">
                        <p class="text-uppercase x-small text-muted mb-2">Level Mix (Last 90 Days)</p>
                        @if (levelMix.Any())
                        {
                            @foreach (var level in levelMix)
                            {
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between small mb-1">
                                        <span>@level.Name</span>
                                        <span>@level.Percent% (@level.Count)</span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar @level.BarClass" role="progressbar" style="width: @level.Percent%;" aria-valuenow="@level.Percent" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="small text-muted mb-0">No level data in the selected period.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-3 pt-3 border-top">
                <p class="text-uppercase x-small text-muted mb-2">Recent Milestones</p>
                @if (milestones.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var milestone in milestones)
                        {
                            <div class="milestone-pill">
                                <span class="badge @milestone.BadgeClass me-2">@milestone.Type</span>
                                <span class="small fw-semibold">@milestone.Title</span>
                                <span class="x-small text-muted ms-2">@milestone.Date.ToString("MMM d, yyyy")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="small text-muted mb-0">No recent milestones found.</p>
                }
            </div>
        </div>
    </div>

    <!-- Monthly Progress Chart -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-0 pt-3 pb-0">
                    <h5 class="fw-semibold mb-0"><i class="bi bi-bar-chart-fill text-primary me-2"></i>Monthly Progress</h5>
                </div>
                <div class="card-body">
                    <canvas id="monthlyChart" style="max-height:280px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-0 pt-3 pb-0">
                    <h5 class="fw-semibold mb-0"><i class="bi bi-pie-chart-fill text-success me-2"></i>By Role</h5>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="roleChart" style="max-height:260px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Modules -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
            <h5 class="fw-semibold mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Recent Modules</h5>
            <a href="modules" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                @foreach (var module in _transcript.ModulesCompleted
                    .OrderByDescending(m => m.CompletionDate)
                    .Take(10))
                {
                    <a href="@module.LearnUrl" target="_blank" rel="noopener" class="list-group-item list-group-item-action px-4 py-3">
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrEmpty(module.IconUrl))
                            {
                                <img src="@module.IconUrl" alt="" width="40" height="40" class="rounded" style="object-fit:contain;" />
                            }
                            else
                            {
                                <div class="module-icon-placeholder rounded">
                                    <i class="bi bi-book-fill text-primary"></i>
                                </div>
                            }
                            <div class="flex-grow-1 min-width-0">
                                <div class="fw-semibold text-truncate">@module.Title</div>
                                <div class="small text-muted">
                                    @if (module.CompletionDate.HasValue)
                                    {
                                        <span><i class="bi bi-calendar3 me-1"></i>@module.CompletionDate.Value.ToString("MMM d, yyyy")</span>
                                    }
                                    <span class="ms-2"><i class="bi bi-clock me-1"></i>@module.Duration min</span>
                                    <span class="ms-2"><i class="bi bi-star me-1"></i>@module.Xp XP</span>
                                </div>
                            </div>
                            @foreach (var level in module.Levels.Take(1))
                            {
                                <span class="badge @LevelBadgeClass(level) d-none d-sm-inline">@level</span>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Certifications preview -->
    @if (activeCertifications.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-semibold mb-0"><i class="bi bi-patch-check-fill text-danger me-2"></i>Active Certifications</h5>
                <a href="achievements" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var cert in activeCertifications.Take(4))
                    {
                        <div class="col-12 col-md-6">
                            <div class="cert-card d-flex align-items-center gap-3 p-3 rounded border">
                                @if (!string.IsNullOrEmpty(cert.IconUrl))
                                {
                                    <img src="@cert.IconUrl" alt="" width="50" height="50" style="object-fit:contain;" />
                                }
                                <div>
                                    <div class="fw-semibold small">@cert.Title</div>
                                    @if (cert.DateEarned.HasValue)
                                    {
                                        <div class="text-muted x-small">Earned: @cert.DateEarned.Value.ToString("MMM yyyy")</div>
                                    }
                                    @if (cert.ExpirationDate.HasValue)
                                    {
                                        var expired = cert.ExpirationDate.Value < DateTime.UtcNow;
                                        <div class="@(expired ? "text-danger" : "text-success") x-small">
                                            @(expired ? "Expired" : "Valid until"): @cert.ExpirationDate.Value.ToString("MMM yyyy")
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (historicalCertifications.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-semibold mb-0"><i class="bi bi-clock-history text-secondary me-2"></i>Historical Certifications</h5>
                <a href="achievements" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var cert in historicalCertifications.Take(4))
                    {
                        <div class="col-12 col-md-6">
                            <div class="cert-card d-flex align-items-center gap-3 p-3 rounded border">
                                @if (!string.IsNullOrEmpty(cert.IconUrl))
                                {
                                    <img src="@cert.IconUrl" alt="" width="50" height="50" style="object-fit:contain;" />
                                }
                                <div>
                                    <div class="fw-semibold small">@cert.Title</div>
                                    @if (cert.DateEarned.HasValue)
                                    {
                                        <div class="text-muted x-small">Earned: @cert.DateEarned.Value.ToString("MMM yyyy")</div>
                                    }
                                    @if (cert.ExpirationDate.HasValue)
                                    {
                                        var expired = cert.ExpirationDate.Value < DateTime.UtcNow;
                                        <div class="@(expired ? "text-danger" : "text-success") x-small">
                                            @(expired ? "Expired" : "Valid until"): @cert.ExpirationDate.Value.ToString("MMM yyyy")
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Applied Skills preview -->
    @if (_transcript.AppliedSkills.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-semibold mb-0"><i class="bi bi-mortarboard-fill text-info me-2"></i>Applied Skills</h5>
                <a href="achievements" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var skill in _transcript.AppliedSkills.OrderByDescending(s => s.AwardedOn).Take(4))
                    {
                        <div class="col-12 col-md-6">
                            <div class="cert-card d-flex align-items-center gap-3 p-3 rounded border">
                                @if (!string.IsNullOrEmpty(skill.IconUrl))
                                {
                                    <img src="@skill.IconUrl" alt="" width="50" height="50" style="object-fit:contain;" />
                                }
                                else
                                {
                                    <div class="cert-icon-placeholder flex-shrink-0" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                        <i class="bi bi-award-fill text-info"></i>
                                    </div>
                                }
                                <div>
                                    <div class="fw-semibold small">@skill.Title</div>
                                    @if (skill.AwardedOn.HasValue)
                                    {
                                        <div class="text-muted x-small">Awarded: @skill.AwardedOn.Value.ToString("MMM yyyy")</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Trophies preview -->
    @if (_transcript.Trophies.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-semibold mb-0"><i class="bi bi-trophy-fill text-warning me-2"></i>Recent Trophies</h5>
                <a href="achievements" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var trophy in _transcript.Trophies.OrderByDescending(t => t.EarnedDate).Take(6))
                    {
                        <div class="col-6 col-sm-4 col-md-2">
                            <div class="text-center p-2">
                                @if (!string.IsNullOrEmpty(trophy.IconUrl))
                                {
                                    <img src="@trophy.IconUrl" alt="@trophy.Title" width="56" height="56"
                                         class="mb-1" style="object-fit:contain;" />
                                }
                                else
                                {
                                    <i class="bi bi-trophy-fill text-warning fs-2 d-block mb-1"></i>
                                }
                                <p class="small fw-semibold mb-0 text-truncate" title="@trophy.Title">@trophy.Title</p>
                                @if (trophy.EarnedDate.HasValue)
                                {
                                    <p class="x-small text-muted mb-0">@trophy.EarnedDate.Value.ToString("MMM yyyy")</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <p class="text-muted small text-end">
        <i class="bi bi-arrow-clockwise me-1"></i>Data refreshed daily via GitHub Actions
    </p>
}

@code {
    private sealed record MomentumInsight(int Score, int Last30, int Previous30, int Last90, int Delta30, string Summary);
    private sealed record FocusShiftItem(string Name, int CurrentCount, int PreviousCount, int Delta);
    private sealed record LevelMixItem(string Name, int Count, int Percent, string BarClass);
    private sealed record MilestoneItem(DateTime Date, string Type, string Title, string BadgeClass);

    private bool _loading = true;
    private string? _error;
    private TranscriptData? _transcript;
    private bool _chartsRendered;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _transcript = await TranscriptSvc.GetTranscriptAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_chartsRendered && _transcript != null)
        {
            _chartsRendered = true;
            await RenderChartsAsync();
        }
    }

    private async Task RenderChartsAsync()
    {
        if (_transcript == null) return;

        // Monthly chart: modules per month for the last 12 months
        var monthly = _transcript.ModulesCompleted
            .Where(m => m.CompletionDate.HasValue)
            .GroupBy(m => new { m.CompletionDate!.Value.Year, Month = m.CompletionDate.Value.Month })
            .OrderBy(g => g.Key.Year).ThenBy(g => g.Key.Month)
            .TakeLast(12)
            .ToList();

        var monthLabels = monthly.Select(g => new DateTime(g.Key.Year, g.Key.Month, 1).ToString("MMM yy")).ToArray();
        var monthData = monthly.Select(g => (object)g.Count()).ToArray();

        await JS.InvokeVoidAsync("createBarChart", "monthlyChart", monthLabels, monthData,
            "Modules Completed", "rgba(13, 110, 253, 0.8)");

        // Role distribution
        var roles = _transcript.ModulesCompleted
            .SelectMany(m => m.Roles)
            .Select(GroupRole)
            .GroupBy(roleGroup => roleGroup)
            .OrderByDescending(g => g.Count())
            .Take(6)
            .ToList();

        if (roles.Any())
        {
            var roleLabels = roles.Select(g => g.Key).ToArray();
            var roleData = roles.Select(g => (object)g.Count()).ToArray();
            await JS.InvokeVoidAsync("createDoughnutChart", "roleChart", roleLabels, roleData);
        }

        // Momentum sparkline: cumulative modules in trailing 7/30/90 day windows
        var now = DateTime.UtcNow;
        var dated = _transcript.ModulesCompleted
            .Where(m => m.CompletionDate.HasValue)
            .Select(m => m.CompletionDate!.Value)
            .ToList();
        var sparklineLabels = new[] { "7d", "30d", "90d" };
        var sparklineData = new object[]
        {
            dated.Count(d => d >= now.AddDays(-7)),
            dated.Count(d => d >= now.AddDays(-30)),
            dated.Count(d => d >= now.AddDays(-90)),
        };
        await JS.InvokeVoidAsync("createSparklineChart", "momentumSparkline", sparklineLabels, sparklineData,
            "rgba(13, 110, 253, 1)");
    }

    private static string LevelBadgeClass(string level) => level.ToLower() switch
    {
        "beginner" => "bg-success-subtle text-success border border-success-subtle",
        "intermediate" => "bg-warning-subtle text-warning border border-warning-subtle",
        "advanced" => "bg-danger-subtle text-danger border border-danger-subtle",
        _ => "bg-secondary-subtle text-secondary border border-secondary-subtle"
    };

    private static MomentumInsight BuildMomentumInsight(IEnumerable<CompletedModule> modules)
    {
        var now = DateTime.UtcNow;
        var last30Start = now.AddDays(-30);
        var prev30Start = now.AddDays(-60);
        var last90Start = now.AddDays(-90);
        var prev90Start = now.AddDays(-180);

        var dated = modules.Where(m => m.CompletionDate.HasValue).Select(m => m.CompletionDate!.Value).ToList();
        var last30 = dated.Count(d => d >= last30Start);
        var previous30 = dated.Count(d => d >= prev30Start && d < last30Start);
        var last90 = dated.Count(d => d >= last90Start);
        var previous90 = dated.Count(d => d >= prev90Start && d < last90Start);

        var delta30 = last30 - previous30;
        var delta90 = last90 - previous90;

        var score = 50
            + Math.Clamp(delta30 * 3, -20, 20)
            + Math.Clamp(delta90, -15, 15)
            + Math.Min(15, last30 / 2);
        score = Math.Clamp(score, 0, 100);

        var summary = delta30 switch
        {
            > 3 => "Your learning pace is accelerating.",
            < -3 => "Your recent pace cooled compared to the previous month.",
            _ => "Your learning pace is steady month-over-month."
        };

        return new MomentumInsight(score, last30, previous30, last90, delta30, summary);
    }

    private static List<FocusShiftItem> BuildFocusShift(
        IEnumerable<CompletedModule> modules,
        Func<CompletedModule, IEnumerable<string>> selector,
        Func<string, string> formatter)
    {
        var now = DateTime.UtcNow;
        var currentStart = now.AddDays(-90);
        var previousStart = now.AddDays(-180);

        var current = modules
            .Where(m => m.CompletionDate.HasValue && m.CompletionDate.Value >= currentStart)
            .SelectMany(selector)
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .GroupBy(v => v.Trim().ToLowerInvariant())
            .ToDictionary(g => g.Key, g => g.Count());

        var previous = modules
            .Where(m => m.CompletionDate.HasValue && m.CompletionDate.Value >= previousStart && m.CompletionDate.Value < currentStart)
            .SelectMany(selector)
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .GroupBy(v => v.Trim().ToLowerInvariant())
            .ToDictionary(g => g.Key, g => g.Count());

        return current
            .Select(kvp =>
            {
                previous.TryGetValue(kvp.Key, out var previousCount);
                var delta = kvp.Value - previousCount;
                return new FocusShiftItem(formatter(kvp.Key), kvp.Value, previousCount, delta);
            })
            .OrderByDescending(i => i.CurrentCount)
            .ThenByDescending(i => i.Delta)
            .ToList();
    }

    private static List<LevelMixItem> BuildLevelMix(IEnumerable<CompletedModule> modules, int days)
    {
        var start = DateTime.UtcNow.AddDays(-days);
        var levels = modules
            .Where(m => m.CompletionDate.HasValue && m.CompletionDate.Value >= start)
            .SelectMany(m => m.Levels)
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .GroupBy(l => l.Trim().ToLowerInvariant())
            .ToDictionary(g => g.Key, g => g.Count());

        var total = levels.Values.Sum();
        if (total == 0)
            return [];

        var order = new[] { "beginner", "intermediate", "advanced" };
        return order
            .Where(levels.ContainsKey)
            .Select(level => new LevelMixItem(
                level[..1].ToUpperInvariant() + level[1..],
                levels[level],
                (int)Math.Round(levels[level] * 100d / total),
                level switch
                {
                    "beginner" => "bg-success",
                    "intermediate" => "bg-warning",
                    "advanced" => "bg-danger",
                    _ => "bg-secondary"
                }))
            .ToList();
    }

    private static List<MilestoneItem> BuildMilestones(
        IEnumerable<Certification> activeCertifications,
        IEnumerable<Certification> historicalCertifications,
        IEnumerable<AppliedSkillCredential> appliedSkills,
        IEnumerable<Trophy> trophies)
    {
        var milestones = new List<MilestoneItem>();

        milestones.AddRange(activeCertifications
            .Where(c => c.DateEarned.HasValue)
            .Select(c => new MilestoneItem(c.DateEarned!.Value, "Active Cert", c.Title ?? "Certification", "bg-danger-subtle text-danger")));

        milestones.AddRange(historicalCertifications
            .Where(c => c.DateEarned.HasValue)
            .Select(c => new MilestoneItem(c.DateEarned!.Value, "Historical Cert", c.Title ?? "Certification", "bg-secondary-subtle text-secondary")));

        milestones.AddRange(appliedSkills
            .Where(s => s.AwardedOn.HasValue)
            .Select(s => new MilestoneItem(s.AwardedOn!.Value, "Applied Skill", s.Title ?? "Applied Skill", "bg-info-subtle text-info")));

        milestones.AddRange(trophies
            .Where(t => t.EarnedDate.HasValue)
            .Select(t => new MilestoneItem(t.EarnedDate!.Value, "Trophy", t.Title ?? "Trophy", "bg-warning-subtle text-warning")));

        return milestones
            .OrderByDescending(m => m.Date)
            .Take(8)
            .ToList();
    }

    private static string GroupRole(string role)
    {
        var normalizedRole = role.Trim().ToLowerInvariant();
        return normalizedRole switch
        {
            "ai-edge-engineer" or
            "ai-engineer" or
            "developer" or
            "devops-engineer" or
            "data-engineer" or
            "platform-engineer" or
            "network-engineer" or
            "security-engineer" or
            "security-operations-analyst" => "Engineering",

            "data-analyst" or
            "data-scientist" or
            "database-administrator" => "Data and AI",

            "solution-architect" or
            "administrator" or
            "identity-access-admin" or
            "ip-admin" or
            "technology-manager" => "Architecture and IT Ops",

            "business-analyst" or
            "business-leader" or
            "business-owner" or
            "business-user" or
            "startup-founder" or
            "maker" => "Business and Product",

            "auditor" or
            "privacy-manager" or
            "risk-practitioner" => "Governance and Risk",

            "student" or
            "k-12-educator" or
            "higher-ed-educator" or
            "school-leader" or
            "functional-consultant" or
            "service-adoption-specialist" => "Education and Adoption",

            _ => "Other"
        };
    }

    private static string FormatProduct(string product)
    {
        return product switch
        {
            "m365" => "M365",
            "dotnet" => ".NET",
            "entra-id" => "Entra ID",
            _ => string.Join(" ", product
                .Split('-', StringSplitOptions.RemoveEmptyEntries)
                .Select(p => p.Length switch
                {
                    0 => p,
                    1 => p.ToUpperInvariant(),
                    _ => char.ToUpperInvariant(p[0]) + p[1..]
                }))
        };
    }
